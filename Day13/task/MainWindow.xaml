<Window x:Class="EmployeeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет сотрудников" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Сотрудники">
                <MenuItem Header="Добавить" Command="{Binding AddCommand}"/>
                <MenuItem Header="Редактировать" Command="{Binding EditCommand}"/>
                <Separator/>
                <MenuItem Header="Удалить" Command="{Binding DeleteCommand}"/>
            </MenuItem>
            <MenuItem Header="Отчёты"/>
            <MenuItem Header="Настройки"/>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding AddCommand}" Content="Добавить"/>
            <Button Command="{Binding EditCommand}" Content="Редактировать"/>
            <Button Command="{Binding DeleteCommand}" Content="Удалить"/>
        </ToolBar>

        <DataGrid ItemsSource="{Binding Employees}" 
                  SelectedItem="{Binding SelectedEmployee}"
                  AutoGenerateColumns="False"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>