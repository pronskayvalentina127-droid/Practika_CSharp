<Window x:Class="EmployeeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Автоматизация учета сотрудников" 
        Height="600" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <ControlTemplate x:Key="AddButtonTemplate" TargetType="Button">
            <Border Background="#4CAF50" CornerRadius="5" Padding="10,5">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <DataTemplate x:Key="EmployeeCardTemplate">
            <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding Position}" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Сотрудники">
                <MenuItem Header="Добавить" Command="{Binding AddCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="Редактировать" Command="{Binding EditCommand}" InputGestureText="Ctrl+E"/>
                <Separator/>
                <MenuItem Header="Удалить" Command="{Binding DeleteCommand}" InputGestureText="Ctrl+D"/>
            </MenuItem>
            <MenuItem Header="Отчёты">
                <MenuItem Header="Все сотрудники" Click="ReportAll_Click"/>
                <MenuItem Header="По должностям" Click="ReportByPosition_Click"/>
            </MenuItem>
            <MenuItem Header="Настройки">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding AddCommand}" ToolTip="Добавить (Ctrl+N)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Добавить"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding EditCommand}" ToolTip="Редактировать (Ctrl+E)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Редактировать"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding DeleteCommand}" ToolTip="Удалить (Ctrl+D)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Удалить"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Фильтр по должности:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cbFilter" Width="150" SelectionChanged="CbFilter_SelectionChanged">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="Разработчик"/>
                    <ComboBoxItem Content="Менеджер"/>
                    <ComboBoxItem Content="Аналитик"/>
                </ComboBox>
            </StackPanel>

            <ListBox Grid.Row="1" x:Name="lbEmployees" 
                     ItemsSource="{Binding Employees}"
                     SelectedItem="{Binding SelectedEmployee}"
                     ItemTemplate="{StaticResource EmployeeCardTemplate}"
                     Margin="0,0,0,10"/>

            <GroupBox Grid.Row="2" Header="Редактирование сотрудника">
                <StackPanel Margin="10">
                    <TextBlock Text="ФИО:" FontWeight="Bold"/>
                    <TextBox Text="{Binding SelectedEmployee.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,10"/>

                    <TextBlock Text="Должность:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedEmployee.Position, Mode=OneWay}"
                               Background="#EEE" Padding="5" Margin="0,5,0,10"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Template="{StaticResource AddButtonTemplate}" 
                                Content="Добавить" Command="{Binding AddCommand}" Margin="5"/>
                        <Button Content="Редактировать" Command="{Binding EditCommand}" Margin="5"
                                Background="#2196F3" Foreground="White" Padding="10,5"/>
                        <Button Content="Удалить" Command="{Binding DeleteCommand}" Margin="5"
                                Background="#F44336" Foreground="White" Padding="10,5"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>