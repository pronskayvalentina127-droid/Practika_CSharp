<Window x:Class="Day15.Views.EditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сотрудник" Height="260" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="ФИО:" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
        <TextBox x:Name="txtFullName" Grid.Row="0" Grid.Column="1" Height="35" Margin="10,5,0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Должность:" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
        <ComboBox x:Name="cbPosition" Grid.Row="1" Grid.Column="1" Height="35" Margin="10,5,0,5">
            <ComboBoxItem Content="Разработчик"/>
            <ComboBoxItem Content="Менеджер"/>
            <ComboBoxItem Content="Аналитик"/>
        </ComboBox>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
            <Button x:Name="btnOk" Content="OK" Width="90" Height="35" Margin="5" Click="BtnOk_Click" Background="#4CAF50" Foreground="White"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="90" Height="35" Margin="5" Click="BtnCancel_Click" Background="#9E9E9E" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>