<Window x:Class="Day15.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Day15.ViewModels"
        xmlns:converters="clr-namespace:Day15.Converters"
        Title="Автоматизация учета сотрудников" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <ControlTemplate x:Key="AddButtonTemplate" TargetType="Button">
            <Border Background="#4CAF50" CornerRadius="8" Padding="12,6">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <DataTemplate x:Key="EmployeeCardTemplate">
            <Border BorderBrush="#DDD" BorderThickness="1" Margin="5" Padding="12" CornerRadius="8" Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding Position}" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <!-- Меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Сотрудники">
                <MenuItem Header="Добавить" Command="{Binding AddCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="Редактировать" Command="{Binding EditCommand}" InputGestureText="Ctrl+E"/>
                <Separator/>
                <MenuItem Header="Удалить" Command="{Binding DeleteCommand}" InputGestureText="Ctrl+D"/>
            </MenuItem>
            <MenuItem Header="Отчёты">
                <MenuItem Header="Все сотрудники" Click="ReportAll_Click"/>
            </MenuItem>
            <MenuItem Header="Настройки">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Панель инструментов -->
        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding AddCommand}" ToolTip="Добавить (Ctrl+N)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Добавить"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding EditCommand}" ToolTip="Редактировать (Ctrl+E)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Редактировать"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding DeleteCommand}" ToolTip="Удалить (Ctrl+D)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Удалить"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- Контент -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ProgressBar -->
            <ProgressBar Grid.Row="0" Height="8" Margin="0,0,0,10"
                         IsIndeterminate="{Binding IsLoading}"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Фильтры -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Отдел:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <ComboBox Width="150" ItemsSource="{Binding Departments}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding SelectedDepartmentId}"/>

                <TextBlock Text="Должность:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="Bold"/>
                <ComboBox x:Name="cbPosition" Width="120" SelectionChanged="CbPosition_SelectionChanged">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="Разработчик"/>
                    <ComboBoxItem Content="Менеджер"/>
                    <ComboBoxItem Content="Аналитик"/>
                </ComboBox>
            </StackPanel>

            <!-- Список карточек -->
            <TextBlock Grid.Row="2" Text="Список сотрудников" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <ListBox Grid.Row="3" x:Name="lbEmployees" 
                     ItemsSource="{Binding Employees}"
                     SelectedItem="{Binding SelectedEmployee}"
                     ItemTemplate="{StaticResource EmployeeCardTemplate}"
                     Margin="0,0,0,10"/>

            <!-- Редактирование -->
            <GroupBox Grid.Row="4" Header="Редактирование сотрудника" Margin="0,5,0,0">
                <StackPanel Margin="10">
                    <TextBlock Text="ФИО:" FontWeight="Bold"/>
                    <TextBox Text="{Binding SelectedEmployee.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" Height="30"/>

                    <TextBlock Text="Должность:" FontWeight="Bold"/>
                    <TextBox Text="{Binding SelectedEmployee.Position, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" Height="30"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Template="{StaticResource AddButtonTemplate}" Content="Добавить" Command="{Binding AddCommand}" Margin="5" Width="100" Height="35"/>
                        <Button Content="Редактировать" Command="{Binding EditCommand}" Margin="5" Width="100" Height="35" Background="#2196F3" Foreground="White"/>
                        <Button Content="Удалить" Command="{Binding DeleteCommand}" Margin="5" Width="100" Height="35" Background="#F44336" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>